rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Chat rooms ────────────────────────────────────────────────────────────
    // Mỗi user chỉ đọc/ghi được phòng chat của chính họ (chatId = userId).
    // Admin (role = 'admin') có thể đọc/ghi tất cả phòng chat.
    match /chats/{chatId} {
      allow read, write: if request.auth != null &&
        (request.auth.uid == chatId || isAdmin());

      match /messages/{messageId} {
        allow read: if request.auth != null &&
          (request.auth.uid == chatId || isAdmin());

        allow create: if request.auth != null &&
          (request.auth.uid == chatId || isAdmin()) &&
          request.resource.data.keys().hasAll(['senderId', 'senderName', 'text', 'isRead', 'timestamp']);

        allow update: if request.auth != null &&
          (request.auth.uid == chatId || isAdmin()) &&
          // Chỉ cho phép update field 'isRead'
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      }
    }

    // ── Helper function ───────────────────────────────────────────────────────
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
